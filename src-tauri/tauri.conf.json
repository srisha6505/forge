{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Forge",
  "version": "0.2.3",
  "identifier": "dev.forge.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Forge",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "category": "Productivity",
    "shortDescription": "AI-augmented markdown editor with interactive widgets",
    "longDescription": "Forge is a desktop markdown editor that turns notes into interactive lessons. Generate live HTML/JS widgets in your prose, run local LLMs, embed math and code, and keep everything as plain Markdown in your vault.",
    "copyright": "Copyright (c) 2026 Forge",
    "publisher": "Forge",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "section": "editors"
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  }
}
