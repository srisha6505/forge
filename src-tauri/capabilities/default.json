{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Default capabilities for the main Forge window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    "core:event:default",
    "core:path:default",
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-copy-file",
    "fs:scope-home-recursive",
    "fs:scope-temp-recursive",
    "dialog:allow-save",
    "shell:default",
    "notification:default"
  ]
}
